# ─── Server ──────────────────────────────────────────────
PROJECT_NAME="CarBrain Backend"
API_V1_STR="/api"
ENV=development
BACKEND_PORT=5000
ALLOWED_ORIGINS=["http://localhost:5173"]

# ─── PostgreSQL ──────────────────────────────────────────
# Using credentials from your existing setup (yaaa / yaaa123)
# DB_USER=yaaa
# DB_PASSWORD=yaaa123
# DB_NAME=carbrain
# DB_HOST=localhost
# DB_PORT=5432

# NOT USING BECAUSE DEFAULTS IN COMPOSE

# Combined URL for local Python execution
# DATABASE_URL=postgresql+asyncpg://yaaa:yaaa123@localhost:5432/carbrain

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=your_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── MQTT Broker ─────────────────────────────────────────
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_DTC=MechanicAI/user1/+/DTC

# ─── AI Engine (Agentic Workflow Service) ────────────────
AGENTIC_PORT=8000
LLM_BASE_URL=http://localhost:8000
LLM_ANALYZE_PATH=/api/llm/analyze
LLM_CHAT_PATH=/api/llm/chat
LLM_FULL_REPORT_PATH=/api/llm/full-report
OPENAI_API_KEY=your_openai_or_openrouter_api_key
BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=moonshotai/kimi-k2.6:free
HF_TOKEN=your_hf_token_here

TAVILY_API_KEY=your_tavily_api_key
INTERNAL_API_SECRET="yaser-kathiri-askar-qarzai"

# ─── Mailer ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="CarBrain Diagnostics <your_email@gmail.com>"

# ─── Hugging Face (Optional RAG KB Download) ────────────
# Set these to download the full pre-built RAG database on startup.
# If HF_TOKEN is unset, the container falls back to sample DTC data.
HF_DATASET_REPO=aziz9788/automotive-rag-kb

