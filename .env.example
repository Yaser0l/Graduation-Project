# ─── Server ──────────────────────────────────────────────
PROJECT_NAME="CarBrain Backend"
API_V1_STR="/api"
ENV=development
BACKEND_PORT=5000
ALLOWED_ORIGINS=["*"]

# ─── PostgreSQL ──────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=carbrain
DB_HOST=localhost
DB_PORT=5432

# Combined URL for local Python execution
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/carbrain

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── MQTT Broker ─────────────────────────────────────────
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_DTC=vehicle/+/dtc

# ─── AI Engine (Agentic Workflow Service) ────────────────
AGENTIC_PORT=8000
LLM_BASE_URL=http://sayyartech-llm:8000
LLM_ANALYZE_PATH=/api/llm/analyze
LLM_CHAT_PATH=/api/llm/chat
LLM_FULL_REPORT_PATH=/api/llm/full-report
OPENAI_API_KEY=your_OPENAI_API_KEY_here
BASE_URL=your_BASE_URL_here
LLM_MODEL=glm-5.1
HF_TOKEN=your_HF_TOKEN_here

TAVILY_API_KEY=your_TAVILY_API_KEY_here
INTERNAL_API_SECRET=your_INTERNAL_API_SECRET_here

# ─── Mailer ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="CarBrain Diagnostics <noreply@carbrain.app>"

# ─── RAG Startup ─────────────────────────────────────────
RAG_STARTUP_MODE=sync

# ─── Hugging Face (Optional RAG KB Download) ────────────
# Set these to download the full pre-built RAG database on startup.
# If HF_TOKEN is unset, the container falls back to sample DTC data.
HF_DATASET_REPO=aziz9788/automotive-rag-kb
