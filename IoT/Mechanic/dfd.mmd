%%{init: {"flowchart": {"htmlLabels": false}} }%%
graph TD
    %% --- External Entities ---
    VEHICLE[("Vehicle\nCAN Bus")]
    BROKER[("MQTT Broker")]

    %% --- IoT Device Boundaries ---
    subgraph ESP32S3_DEVICE["IoT Device (ESP32-S3)"]
        
        subgraph Layer1_Ingestion["1. Ingestion"]
            TWAI_DRV["TWAI Driver\n(Native CAN)"]
            ELM_DRV["UART Driver\n(ELM327 Interface)"]
        end

        subgraph Layer2_Core["2. Processing"]
            MSG_CLASS{{"Message\nClassifier"}}
            
            subgraph Interpreters
                RT_INT[["Real-Time\nInterpreter"]]
                DTC_INT[["DTC Response\nParser"]]
            end

            payload_Gen["JSON Payload\nGenerator"]
        end

        subgraph Layer3_Egress["3. Egress"]
            MQTT_CLIENT["MQTT Client"]
            WIFI_DRV["Wi-Fi Stack"]
        end

        ELM_CHIP[("ELM327 Chip")]
    end

    %% --- External Physical Connections ---
    VEHICLE -- "Raw CAN Traffic" --> TWAI_DRV
    VEHICLE <-. "ISO 15765-4" .-> ELM_CHIP
    ELM_CHIP -- "UART ASCII" --> ELM_DRV
    ELM_DRV -- "AT Commands" --> ELM_CHIP

    %% --- Internal Logic Flow ---
    TWAI_DRV --> MSG_CLASS
    ELM_DRV --> MSG_CLASS

    MSG_CLASS -- "Native Frames" --> RT_INT
    MSG_CLASS -- "DTC Strings" --> DTC_INT

    RT_INT --> payload_Gen
    DTC_INT --> payload_Gen

    payload_Gen --> MQTT_CLIENT
    MQTT_CLIENT --> WIFI_DRV
    WIFI_DRV -- "PUBLISH" --> BROKER

    %% --- Styling ---
    style VEHICLE fill:#f9f,stroke:#333
    style BROKER fill:#f9f,stroke:#333
    style ESP32S3_DEVICE fill:#fff,stroke:#000
    style ELM_CHIP fill:#eee,stroke:#f00,stroke-dasharray: 5 5