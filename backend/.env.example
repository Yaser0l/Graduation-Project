# ─── Server ──────────────────────────────────────────────
PROJECT_NAME="CarBrain Backend"
API_V1_STR="/api"
ENV=development
PORT=5000

# ─── PostgreSQL (FastAPI uses DATABASE_URL) ──────────────
# Format: postgresql+asyncpg://user:pass@host:port/db
DATABASE_URL=postgresql+asyncpg://postgres:your_password_here@localhost:5432/carbrain

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── MQTT Broker ─────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_DTC=vehicle/+/dtc

# ─── LLM Endpoint (Developer 3) ─────────────────────────
LLM_BASE_URL=http://localhost:8000
LLM_ANALYZE_PATH=/analyze
LLM_CHAT_PATH=/chat
LLM_API_KEY=

# ─── Mailer ──────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM="CarBrain Diagnostics <noreply@carbrain.app>"
