# Copy to .env and fill in values (never commit .env).

# BigModel / GLM — same variable name works with ChatOpenAI-compatible clients
OPENAI_API_KEY=
BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-5.1

# Optional aliases (config reads these if OPENAI_API_KEY is unset)
# BIGMODEL_API_KEY=
# LLM_API_KEY=

TAVILY_API_KEY=
